# ── AIFA CDSS — Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is read automatically by docker-compose.
#
#   cp .env.example .env

# ── Ports (override if 8000/8001 are already in use on the host) ──────────────
RULE_ENGINE_HOST_PORT=8000
RAG_HOST_PORT=8001

# ── Embedding model ────────────────────────────────────────────────────────────
# Lighter model (768d) — downloads ~420 MB on first run.
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
# Better Italian quality (1024d) — downloads ~1.2 GB:
# EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ── LLM backend (Phase 2 — Orchestrator) ──────────────────────────────────────
# Option A: OpenAI (gpt-4o-mini recommended for cost/quality balance)
OPENAI_API_KEY=

# Option B: Ollama local model (run: ollama pull llama3.1:8b)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── GPU ───────────────────────────────────────────────────────────────────────
# Set to "" to disable GPU and fall back to CPU (for testing without NVIDIA setup)
CUDA_VISIBLE_DEVICES=0

# ── Vector store routing (granular metrics M1/M2 require v2 collections) ──────
# Empty string → use legacy nota_XX collections (NO char/line tracking)
# "_v2"        → use nota_XX_v2 collections (full char/line/sha tracking)
# Default _v2 because v1 collections lack char metadata required by
# evidence_boxes (PROVA NORMATIVA) → without it M1/M2/CCS collapse to ~0.
CHROMA_COLLECTION_SUFFIX=_v2
